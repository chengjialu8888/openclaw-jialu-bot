{
  "crons": [
    {
      "name": "ai-daily-report",
      "schedule": "0 10 * * *",
      "timezone": "Asia/Shanghai",
      "task": "生成每日AI产品动态观察日报",
      "workflow": "WORKFLOWS/ai-daily-report.md",
      "steps": [
        {
          "order": 1,
          "action": "read",
          "target": "WORKFLOWS/ai-daily-report.md",
          "description": "读取工作流配置和自检清单"
        },
        {
          "order": 2,
          "action": "verify_date",
          "description": "确认当前日期和美国日期（考虑时差）"
        },
        {
          "order": 3,
          "action": "search",
          "tool": "coze-web-search",
          "queries": [
            "AI news today March 2026",
            "OpenAI Anthropic Google Gemini news today",
            "字节 AI 产品 2026年3月"
          ],
          "params": {
            "time_range": "1d",
            "count": 15,
            "format": "markdown"
          },
          "description": "搜索24小时内发布的AI新闻"
        },
        {
          "order": 4,
          "action": "verify_sources",
          "description": "交叉验证信源，排除旧闻和转载"
        },
        {
          "order": 5,
          "action": "generate",
          "template": "daily_report",
          "constraints": [
            "只收录已验证的24小时内新闻",
            "标注每条新闻的可信度（✅/⚠️/❌）",
            "如果新闻不足，诚实说明"
          ]
        },
        {
          "order": 6,
          "action": "send",
          "channel": "feishu",
          "target": "Jialu",
          "description": "发送日报到飞书"
        }
      ],
      "quality_checks": {
        "max_old_news_ratio": 0.1,
        "require_official_source": true,
        "require_cross_verification": true,
        "honesty_policy": "宁缺毋滥"
      }
    }
  ]
}
