{
  "version": 1,
  "jobs": [
    {
      "id": "evomap-daily-evolution",
      "name": "EvoMap每日进化+早餐汇报",
      "expr": "30 8 * * *",
      "command": "/workspace/projects/workspace/scripts/evomap_daily.sh",
      "enabled": true,
      "description": "每天早上8:30汇报昨晚EvoMap进化情况：迭代了什么+测试是否成功",
      "state": {
        "scheduleErrorCount": 1,
        "lastError": "schedule error: TypeError: Cannot read properties of undefined (reading 'kind')"
      },
      "wakeMode": "now"
    },
    {
      "id": "ai-daily-news-v2",
      "name": "AI日报-Signex架构版",
      "expr": "0 10 * * *",
      "command": "/workspace/projects/workspace/daily/pipeline/run_daily.sh",
      "enabled": true,
      "description": "每天10:00am执行Signex架构日报：Sensors→Lens→Report→Vault",
      "state": {
        "scheduleErrorCount": 1,
        "lastError": "schedule error: TypeError: Cannot read properties of undefined (reading 'kind')"
      },
      "wakeMode": "now"
    }
  ]
}